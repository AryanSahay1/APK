<!--
  Panda doodle — primary NexOS mascot.
  108x108 viewport so the same drawable can be used as the launcher-icon foreground
  (adaptive icons need a 108x108 surface with a safe inner area of 72x72).
  Drawn as filled paths only — no strokes — so it crisply downscales to any size.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Left ear (outer) -->
    <path
        android:fillColor="#0F0F14"
        android:pathData="M 26,30 m -13,0 a 13,13 0 1,0 26,0 a 13,13 0 1,0 -26,0 Z" />
    <!-- Left ear inner (subtle highlight) -->
    <path
        android:fillColor="#2A2A36"
        android:pathData="M 26,30 m -6,0 a 6,6 0 1,0 12,0 a 6,6 0 1,0 -12,0 Z" />

    <!-- Right ear (outer) -->
    <path
        android:fillColor="#0F0F14"
        android:pathData="M 82,30 m -13,0 a 13,13 0 1,0 26,0 a 13,13 0 1,0 -26,0 Z" />
    <!-- Right ear inner -->
    <path
        android:fillColor="#2A2A36"
        android:pathData="M 82,30 m -6,0 a 6,6 0 1,0 12,0 a 6,6 0 1,0 -12,0 Z" />

    <!-- Head (white doodle face) -->
    <path
        android:fillColor="#FAFAFA"
        android:pathData="M 54,60 m -32,0 a 32,32 0 1,0 64,0 a 32,32 0 1,0 -64,0 Z" />
    <!-- Subtle face shadow on the lower edge so the face has gentle depth -->
    <path
        android:fillColor="#EAEAF0"
        android:pathData="M 54,75 m -24,0 c 0,12 10,17 24,17 c 14,0 24,-5 24,-17 c 0,-2 -1,-3 -3,-3 l -42,0 c -2,0 -3,1 -3,3 Z" />

    <!-- Left eye patch — teardrop tilted toward nose -->
    <path
        android:fillColor="#0F0F14"
        android:pathData="M 42,58 c -7,-1 -12,3 -12,9 c 0,7 5,12 11,12 c 6,0 11,-5 11,-12 c 0,-5 -4,-9 -10,-9 Z" />
    <!-- Right eye patch -->
    <path
        android:fillColor="#0F0F14"
        android:pathData="M 66,58 c 7,-1 12,3 12,9 c 0,7 -5,12 -11,12 c -6,0 -11,-5 -11,-12 c 0,-5 4,-9 10,-9 Z" />

    <!-- Left eye highlight (white) -->
    <path
        android:fillColor="#FAFAFA"
        android:pathData="M 42,65 m -3,0 a 3,3 0 1,0 6,0 a 3,3 0 1,0 -6,0 Z" />
    <!-- Right eye highlight -->
    <path
        android:fillColor="#FAFAFA"
        android:pathData="M 66,65 m -3,0 a 3,3 0 1,0 6,0 a 3,3 0 1,0 -6,0 Z" />
    <!-- Left pupil -->
    <path
        android:fillColor="#0F0F14"
        android:pathData="M 43,66 m -1.2,0 a 1.2,1.2 0 1,0 2.4,0 a 1.2,1.2 0 1,0 -2.4,0 Z" />
    <!-- Right pupil -->
    <path
        android:fillColor="#0F0F14"
        android:pathData="M 67,66 m -1.2,0 a 1.2,1.2 0 1,0 2.4,0 a 1.2,1.2 0 1,0 -2.4,0 Z" />

    <!-- Nose — small heart-like blob -->
    <path
        android:fillColor="#0F0F14"
        android:pathData="M 54,76 c -4,0 -6,3 -6,5 c 0,3 3,5 6,7 c 3,-2 6,-4 6,-7 c 0,-2 -2,-5 -6,-5 Z" />

    <!-- Mouth — a soft 'w' smile -->
    <path
        android:fillColor="#0F0F14"
        android:pathData="M 50,86 c 1,2 2,3 4,3 c 2,0 3,-1 4,-3 c 1,2 2,3 4,3 c 0,0 -2,3 -6,3 c -4,0 -6,-3 -6,-6 Z" />

    <!-- NexOS green accent — a tiny leaf hint above the head for brand color tie-in -->
    <path
        android:fillColor="#00E676"
        android:pathData="M 86,18 c 4,-4 8,-4 12,0 c -2,6 -6,8 -12,8 c 0,-3 0,-6 0,-8 Z" />
</vector>
