<!--
  Launcher background — radial gradient from the NexOS green accent in the upper-left
  out to deep near-black. Gives the panda a subtle "moonlit bamboo" feel that matches
  the in-app theme without ever crossing into visually heavy territory.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:pathData="M0,0 h108 v108 h-108 z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="32"
                android:centerY="28"
                android:gradientRadius="120"
                android:startColor="#1A2A1F"
                android:endColor="#07070F" />
        </aapt:attr>
    </path>
</vector>
