<!--
  Notification small-icon. Android renders this as a flat silhouette tinted by the
  system accent color, so all detail must be conveyed by the silhouette itself —
  two ear bumps + a circular head is enough to read as "panda" at 24dp.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Left ear -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M 6,7 m -3,0 a 3,3 0 1,0 6,0 a 3,3 0 1,0 -6,0 Z" />
    <!-- Right ear -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M 18,7 m -3,0 a 3,3 0 1,0 6,0 a 3,3 0 1,0 -6,0 Z" />
    <!-- Head -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M 12,13 m -7,0 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0 Z" />
</vector>
