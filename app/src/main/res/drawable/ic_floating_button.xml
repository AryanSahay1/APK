        android:fillColor="#0F0F14"
        android:pathData="M 25,43 c 1,1 2,1.4 3,1.4 c 1,0 2,-0.4 3,-1.4 c -0.4,1.6 -1.4,2.4 -3,2.4 c -1.6,0 -2.6,-0.8 -3,-2.4 Z" />
