        android:fillColor="#0F0F14"
        android:pathData="M 28,38 c -1.6,0 -2.6,1 -2.6,2 c 0,1.2 1.2,2.2 2.6,3 c 1.4,-0.8 2.6,-1.8 2.6,-3 c 0,-1 -1,-2 -2.6,-2 Z" />

