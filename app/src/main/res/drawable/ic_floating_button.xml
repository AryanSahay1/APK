<!--
  Floating overlay button — panda doodle on a soft green pill so it pops over any
  background (light apps, dark apps, photos). Designed to read at 56dp.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="56dp"
    android:height="56dp"
    android:viewportWidth="56"
    android:viewportHeight="56">

    <!-- Outer pill — NexOS green disc with a subtle inner ring -->
    <path
        android:fillColor="#00E676"
        android:pathData="M 28,28 m -26,0 a 26,26 0 1,0 52,0 a 26,26 0 1,0 -52,0 Z" />
    <path
        android:fillColor="#0AB762"
        android:pathData="M 28,28 m -23,0 a 23,23 0 1,0 46,0 a 23,23 0 1,0 -46,0 Z" />
    <path
        android:fillColor="#00E676"
        android:pathData="M 28,28 m -21,0 a 21,21 0 1,0 42,0 a 21,21 0 1,0 -42,0 Z" />

    <!-- Left ear -->
    <path
        android:fillColor="#0F0F14"
        android:pathData="M 16,18 m -5,0 a 5,5 0 1,0 10,0 a 5,5 0 1,0 -10,0 Z" />
    <!-- Right ear -->
    <path
        android:fillColor="#0F0F14"
        android:pathData="M 40,18 m -5,0 a 5,5 0 1,0 10,0 a 5,5 0 1,0 -10,0 Z" />

