        android:fillColor="#FAFAFA"
        android:pathData="M 28,30 m -13,0 a 13,13 0 1,0 26,0 a 13,13 0 1,0 -26,0 Z" />

    <!-- Left eye patch -->
    <path
        android:fillColor="#0F0F14"
        android:pathData="M 22,28 c -3,0 -5,1 -5,4 c 0,3 2,5 5,5 c 3,0 5,-2 5,-5 c 0,-3 -2,-4 -5,-4 Z" />
    <!-- Right eye patch -->
    <path
        android:fillColor="#0F0F14"
        android:pathData="M 34,28 c 3,0 5,1 5,4 c 0,3 -2,5 -5,5 c -3,0 -5,-2 -5,-5 c 0,-3 2,-4 5,-4 Z" />

    <!-- Eye dots -->
