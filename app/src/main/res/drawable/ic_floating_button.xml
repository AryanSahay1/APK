        android:fillColor="#FAFAFA"
        android:pathData="M 22,32 m -1.4,0 a 1.4,1.4 0 1,0 2.8,0 a 1.4,1.4 0 1,0 -2.8,0 Z" />
    <path
        android:fillColor="#FAFAFA"
        android:pathData="M 34,32 m -1.4,0 a 1.4,1.4 0 1,0 2.8,0 a 1.4,1.4 0 1,0 -2.8,0 Z" />

    <!-- Nose -->
